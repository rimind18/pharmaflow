{
  "info": {
    "name": "FharmaFlow API",
    "description": "API Documentation untuk FharmaFlow - Platform E-commerce Apotek",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"081234567890\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"address\": \"Jl. Merdeka No.1\",\n  \"city\": \"Jakarta\",\n  \"province\": \"DKI Jakarta\",\n  \"postal_code\": \"12345\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@pharmaflow.local\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/auth/me",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "me"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/auth/logout",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Medicines",
      "item": [
        {
          "name": "Get All Medicines",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/medicines?per_page=15&page=1",
              "host": ["{{BASE_URL}}"],
              "path": ["medicines"],
              "query": [
                {
                  "key": "per_page",
                  "value": "15"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "search",
                  "value": "paracetamol",
                  "disabled": true
                },
                {
                  "key": "category_id",
                  "value": "1",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Get Medicine Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/medicines/1",
              "host": ["{{BASE_URL}}"],
              "path": ["medicines", "1"]
            }
          }
        },
        {
          "name": "Create Medicine",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Obat Baru\",\n  \"description\": \"Deskripsi obat baru\",\n  \"category_id\": 1,\n  \"supplier_id\": 1,\n  \"base_price\": 5000,\n  \"markup_percentage\": 25,\n  \"unit\": \"pcs\",\n  \"stock_minimum\": 10,\n  \"stock_maximum\": 100\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/medicines",
              "host": ["{{BASE_URL}}"],
              "path": ["medicines"]
            }
          }
        }
      ]
    },
